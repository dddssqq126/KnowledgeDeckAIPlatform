COMPOSE_PROJECT_NAME=knowledgedeck
GPU_DEVICE=0

DATABASE_URL=sqlite+aiosqlite:///./knowledgedeck.db

# Qdrant local-disk mode (embedded in backend process, no separate server):
QDRANT_URL=
QDRANT_PATH=./qdrant_data
QDRANT_COLLECTION=knowledgedeck

# Presenton renders the final PPTX after our LLM produces the outline. The
# AUTH_USERNAME / AUTH_PASSWORD are bootstrapped by the Presenton container
# on first start, so change these BEFORE first compose up if you want a
# different admin credential.
PRESENTON_URL=http://knowledgedeck_presenton:80
PRESENTON_USERNAME=admin
PRESENTON_PASSWORD=change-me-please
# Backend reads PPTX artifacts directly from the shared volume mounted here.
PRESENTON_DATA_ROOT=/presenton_data
# Single-machine object storage (filesystem).
LOCAL_STORAGE_ROOT=/var/lib/knowledgedeck-storage
STORAGE_BUCKET=knowledgedeck

INITIAL_USER_USERNAME=admin
INITIAL_USER_PASSWORD=admin

# URL the BROWSER will use to reach the backend. For local-only dev, leave as
# http://localhost:8080. When running on a remote host (SSH dev), set to the
# host's LAN address, e.g. NEXT_PUBLIC_API_BASE_URL=http://192.168.1.102:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Comma-separated CORS allowed origins. MUST include the URL the browser
# loads the frontend from. Examples:
#   Local-only:  CORS_ORIGINS=http://localhost:3000
#   Remote dev:  CORS_ORIGINS=http://192.168.1.102:3000
# Leave empty in production behind a reverse proxy that strips the Origin header.
CORS_ORIGINS=http://localhost:3000

LLM_BASE_URL=http://knowledgedeck_vllm_chat:8000/v1
LLM_API_KEY=local-dev-key
LLM_MODEL=google/gemma-4-E4B-it
# User-facing label shown in the Chat / Slide Maker headers ("Model: ...").
# Decoupled from LLM_MODEL so the internal model id and the display name
# can change independently.
LLM_MODEL_LABEL=Gemma 4 E4B
VLLM_CHAT_PORT=8000
VLLM_CHAT_GPU_MEMORY_UTILIZATION=0.70
VLLM_CHAT_MAX_MODEL_LEN=16384

# Inside the compose network, vLLM containers listen on 8000. The host-side
# port mapping (VLLM_EMBEDDING_PORT, default 8001) is for browser/manual
# access only — do NOT use it here.
EMBEDDING_BASE_URL=http://knowledgedeck_vllm_embedding:8000/v1
EMBEDDING_API_KEY=local-dev-key
EMBEDDING_MODEL=BAAI/bge-m3
VLLM_EMBEDDING_PORT=8001
VLLM_EMBEDDING_GPU_MEMORY_UTILIZATION=0.08
VLLM_EMBEDDING_MAX_MODEL_LEN=8192

# Reranker (cross-encoder). Lives on its own GPU so it doesn't fight the
# chat model for VRAM. Default device is 3 — change if your box layout
# differs. Set RAG_DENSE_TOP_K (Qdrant fetch) and RAG_FINAL_TOP_K
# (post-rerank window) on the backend side to tune throughput vs recall.
RERANK_BASE_URL=http://knowledgedeck_vllm_rerank:8000/v1
RERANK_API_KEY=local-dev-key
RERANK_MODEL=BAAI/bge-reranker-v2-m3
VLLM_RERANK_PORT=8002
# Default: all three vLLM services share GPU 0. Override per service if you
# want to spread across GPUs (e.g. set VLLM_RERANK_GPU_DEVICE=3 for a
# dedicated rerank GPU).
VLLM_RERANK_GPU_DEVICE=0
VLLM_RERANK_GPU_MEMORY_UTILIZATION=0.08
VLLM_RERANK_MAX_MODEL_LEN=2048
